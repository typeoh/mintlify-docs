  "keyFeatures": [
    "CALM (Conversational AI with Language Models) dialogue system",
    "Flow-based business logic with YAML-defined conversation steps",
    "Automatic handling of conversation patterns (topic changes, corrections, clarifications)",
    "LLM-agnostic via LiteLLM (OpenAI, Azure, Bedrock, Mistral, Gemini, self-hosted)",
    "Rasa Studio no-code visual flow builder",
    "Custom Python actions via Rasa SDK",
    "MCP (Model Context Protocol) tools integration for IDE-assisted development",
    "End-to-end testing framework with E2E test cases",
    "Voice assistant support with real-time speech processing",
    "Kubernetes and Docker deployment with Helm charts",
    "Built-in observability: analytics, tracing (Jaeger, OTEL, Langfuse), conversation review",
    "Enterprise search with RAG (Retrieval-Augmented Generation)",
    "Multi-language support and translation management",
    "Agent-to-agent (A2A) integration and sub-agent orchestration"
  ],
  "publicApiSurface": [
    "rasa init",
    "rasa train",
    "rasa run",
    "rasa run actions",
    "rasa inspect",
    "rasa test e2e",
    "rasa data validate",
    "rasa llm finetune prepare-data",
    "rasa studio config / login / download / upload / push / pull",
    "rasa tools init / run",
    "Action webhook POST /webhook",
    "flows: YAML flow definitions (steps, collect, action, set_slots, call, link)",
    "Slot types: text, bool, float, categorical, any, list",
    "Custom Action: Action.run(dispatcher, tracker, domain)",
    "SlotSet, FollowupAction, BotUttered events",
    "endpoints.yml: action_endpoint, tracker_store, event_broker, model_groups, tracing",
    "config.yml: pipeline, policies, LLM model_group references",
    "E2E test cases YAML: test_cases, user/bot/utter/slot_was_set steps, assertions, fixtures"
  ]
}
